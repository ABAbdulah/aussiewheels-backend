# ──────────────────────────────────────────────────────────────────────────
# Local development
# ──────────────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated list of allowed browser origins. Supports `*` as a wildcard
# for a single URL segment, e.g. `https://*.vercel.app`.
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Railway (production) — set these in the Railway dashboard, NOT in this file
# ──────────────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway — do not override.
# HOST defaults to 0.0.0.0 (correct for Railway).
# NODE_ENV=production               # Railway sets this; enables JSON logs.
# LOG_LEVEL=info
# CORS_ORIGIN=https://aussiewheels.vercel.app,https://*.vercel.app,https://www.aussiewheels.com.au

# Future (Prisma + Postgres):
# DATABASE_URL=postgresql://user:pass@host:5432/aussiewheels
